DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
TARO_APP_ENV=development
TARO_APP_ID=your_weapp_appid_here
TARO_APP_API_BASE=http://127.0.0.1:3000
TARO_APP_AUTH_LOGIN_PATH=/api/auth/wechat/login
TARO_APP_LOGIN_ENABLED=false
TARO_APP_TOKEN_KEY=love-court-business-token
TARO_APP_REFRESH_TOKEN_KEY=love-court-refresh-token

# 微信小程序登录
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# Token 签发密钥（请用随机字符串，至少 32 位）
TOKEN_SECRET=your_token_secret_here_at_least_32_chars
